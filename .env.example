# =============================================================================
# REQUIRED — fill these in to get started
# =============================================================================

UNIFI_HOST=https://192.168.1.1
UNIFI_USER=adguard
UNIFI_PASS=changeme
UNIFI_SITE=default

ADGUARD_HOST=http://192.168.1.2
ADGUARD_USER=admin
ADGUARD_PASS=changeme

# =============================================================================
# OPTIONAL — sensible defaults, no need to change for a basic setup
# =============================================================================

# How often to sync in seconds (0 = run once and exit)
SYNC_INTERVAL=300

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Log what would happen without writing anything to AdGuard
DRY_RUN=false

# Health check endpoint port (0 = disabled)
HEALTH_PORT=8080

# Remove AdGuard clients not seen in UniFi for this many days (0 = disabled)
STALE_AFTER_DAYS=0
STATE_FILE=/data/state.json

# Skip SSL verification for self-signed UniFi certificates
UNIFI_VERIFY_SSL=false

# =============================================================================
# ADVANCED — DNS rewrites
# Syncs hostname→IP so devices are reachable by name (e.g. ssh myserver.home.local)
# =============================================================================

DNS_REWRITE_ENABLED=false
DNS_REWRITE_DOMAIN=home.local

# Tags to exclude from rewrites. By default only PCs, laptops, NAS and
# unrecognised devices get a rewrite; phones/tablets/IoT are skipped.
# Uncomment and edit to override:
# DNS_REWRITE_EXCLUDE_TAGS=device_phone,device_tablet,device_tv,device_camera,device_audio,device_printer,device_gameconsole,device_securityalarm

# Only create rewrites for clients on these VLANs (empty = all VLANs):
# DNS_REWRITE_VLANS=10,20

# Skip rewrites for devices on these VLANs, unless their device tag is not excluded
# (e.g. a laptop on an IoT VLAN still gets a rewrite):
# DNS_REWRITE_EXCLUDE_VLANS=30,40

# =============================================================================
# ADVANCED — VLAN filtering & tagging
# =============================================================================

# Only sync clients on these VLANs (comma-separated). Pick one or neither:
# INCLUDE_VLANS=10,20,30
# EXCLUDE_VLANS=99,100

# Map VLAN IDs to AdGuard OS tags (comma-separated VLAN:tag pairs):
# VLAN_OS_MAP=200:os_windows,300:os_linux

# =============================================================================
# OPTIONAL — Web dashboard
# =============================================================================

# Web dashboard port (0 = disabled)
DASHBOARD_PORT=8888
